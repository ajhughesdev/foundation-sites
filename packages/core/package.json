{
  "name": "@foundation/core",
  "version": "0.0.0",
  "description": "Foundation 7 core runtime (DOM-first, ESM-first).",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./utils/dom.js": {
      "types": "./dist/utils/dom.d.ts",
      "import": "./dist/utils/dom.js"
    },
    "./utils/floating.js": {
      "types": "./dist/utils/floating.d.ts",
      "import": "./dist/utils/floating.js"
    },
    "./utils/focusTrap.js": {
      "types": "./dist/utils/focusTrap.d.ts",
      "import": "./dist/utils/focusTrap.js"
    },
    "./utils/inert.js": {
      "types": "./dist/utils/inert.d.ts",
      "import": "./dist/utils/inert.js"
    },
    "./utils/schedule.js": {
      "types": "./dist/utils/schedule.d.ts",
      "import": "./dist/utils/schedule.js"
    },
    "./utils/scrollLock.js": {
      "types": "./dist/utils/scrollLock.d.ts",
      "import": "./dist/utils/scrollLock.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ../../scripts/f7-clean-dist.js dist && tsc -p tsconfig.json"
  }
}
